{
	"name": "directus-extension-downloadfolderorfilesaszip-endpoint",
	"description": "Directus custom endpoint extension allowing to download and save folder content or multiple files as zip.",
	"icon": "extension",
	"license": "MIT",
	"version": "1.0.0",
    "author": "Euryece Telecom",
	"keywords": [
		"directus",
		"directus-extension",
		"directus-extension-endpoint"
	],
	"type": "module",
	"files": [
		"dist"
	],
	"directus:extension": {
		"type": "endpoint",
		"path": "dist/index.js",
		"source": "src/index.ts",
		"host": "^10.10.0"
	},
	"scripts": {
		"build": "directus-extension build",
		"dev": "directus-extension build -w --no-minify",
		"link": "directus-extension link",
		"validate": "directus-extension validate"
	},
	"devDependencies": {
		"@directus/extensions-sdk": "16.0.2",
		"@types/archiver": "^6.0.3",
		"@types/node": "^24.5.2",
		"typescript": "^5.9.2"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/euryecetelecom/directus-extension-downloadfolderorfilesaszip-endpoint.git"
	},
	"homepage": "https://github.com/euryecetelecom/directus-extension-downloadfolderorfilesaszip-endpoint",
	"publishConfig": {
		"access": "public"
	},
	"dependencies": {
		"archiver": "^7.0.1"
	}
}
